{
  "mcpServers": {
    "n8n-mcp": {
      "command": "npx",
      "args": ["n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "LOG_LEVEL": "error",
        "N8N_API_URL": "https://YOUR-INSTANCE.app.n8n.cloud",
        "N8N_API_KEY": "PASTE_YOUR_N8N_API_KEY_HERE"
      }
    }
  }
}
